# Shared VHS settings for all hazmat tapes.
# Usage: Source assets/config.tape

Set Shell "zsh"
Set FontSize 20
Set FontFamily "JetBrains Mono"
Set Width 1100
Set Height 600
Set Padding 20
Set Theme "Catppuccin Mocha"
Set TypingSpeed 50ms
Set WindowBar Colorful
Set BorderRadius 8
Set Margin 10
Set MarginFill "#1e1e2e"
Set Framerate 24
Set CursorBlink false
Set MaxColors 128
